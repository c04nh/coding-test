# -*- coding: utf-8 -*-
# UTF-8 encoding when using korean
N, M = map(int, input().split())
A = []
B = []

for i in range(N):
	A.append(list(map(int, input().split())))

for i in range(N):
	B.append(list(map(int, input().split())))

for i in range(N):
	for j in range(M):
		if j != 0:
			print(' ', end='')
		print(A[i][j]+B[i][j], end='')
	print()
	
